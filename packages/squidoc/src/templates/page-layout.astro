---
const { data } = Astro.props;
const {
  site,
  page,
  layout,
  classes,
  globalCss,
  headHtml,
  headerLinksHtml,
  footer,
  footerLinksHtml,
  navHtml,
  slots,
} = data;
const isDocsLayout = layout === "docs";
---

<html lang={page.lang ?? "en"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{page.title} | {site.name}</title>
    {page.description && <meta name="description" content={page.description} />}
    <Fragment set:html={headHtml} />
    <style set:html={globalCss}></style>
  </head>
  <body>
    <svg class="sq-icon-sprite" aria-hidden="true" focusable="false">
      <symbol id="sq-icon-menu" viewBox="0 0 24 24">
        <path d="M4 7h16M4 12h16M4 17h16"></path>
      </symbol>
      <symbol id="sq-icon-search" viewBox="0 0 24 24">
        <circle cx="11" cy="11" r="7"></circle>
        <path d="m16.5 16.5 3.5 3.5"></path>
      </symbol>
      <symbol id="sq-icon-chevron-right" viewBox="0 0 24 24">
        <path d="m9 18 6-6-6-6"></path>
      </symbol>
    </svg>
    <input
      class="sq-sidebar-control"
      id="squidoc-sidebar-toggle"
      type="checkbox"
      aria-label="Toggle documentation navigation"
    />
    <header class="sq-topbar">
      <a class="sq-topbar__brand" href="/">
        <img class="sq-topbar__logo" src="/squidoc-logo.svg" alt="" />
        <span class="sq-topbar__brand-text">{site.name}</span>
      </a>
      <Fragment set:html={slots.search} />
      <nav class="sq-topbar__nav" aria-label="Site">
        <Fragment set:html={headerLinksHtml} />
      </nav>
      <Fragment set:html={slots.localeSelector} />
      <label class="sq-sidebar-toggle" for="squidoc-sidebar-toggle">
        <svg class="sq-icon" aria-hidden="true" focusable="false">
          <use href="#sq-icon-menu"></use>
        </svg>
        <span>Menu</span>
      </label>
    </header>
    {
      isDocsLayout ? (
        <div class={classes.shell}>
          <aside class={classes.sidebar}>
            <Fragment set:html={slots.versionSelector} />
            <nav class={classes.nav} aria-label="Documentation">
              <Fragment set:html={navHtml} />
            </nav>
          </aside>
          <div class="sq-page">
            <main class={classes.content}>
              <slot />
            </main>
          </div>
          <aside class="sq-article-tree">
            <Fragment set:html={slots.articleTree} />
          </aside>
          <footer class="sq-footer">
            {footer.text && <p class="sq-footer__text">{footer.text}</p>}
            <nav class="sq-footer__nav" aria-label="Footer">
              <Fragment set:html={footerLinksHtml} />
            </nav>
          </footer>
        </div>
      ) : (
        <div class="sq-page-shell">
          <main class="sq-page-content">
            <slot />
          </main>
          <footer class="sq-footer">
            {footer.text && <p class="sq-footer__text">{footer.text}</p>}
            <nav class="sq-footer__nav" aria-label="Footer">
              <Fragment set:html={footerLinksHtml} />
            </nav>
          </footer>
        </div>
      )
    }
  </body>
</html>
