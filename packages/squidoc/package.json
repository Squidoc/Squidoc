{
  "name": "squidoc",
  "version": "0.1.0",
  "description": "CLI for the Squidoc documentation platform.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "homepage": "https://github.com/Squidoc/Squidoc#readme",
  "bugs": {
    "url": "https://github.com/Squidoc/Squidoc/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Squidoc/Squidoc.git",
    "directory": "packages/squidoc"
  },
  "keywords": ["docs", "documentation", "cli", "squidoc", "static-site"],
  "bin": {
    "squidoc": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-templates.mjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@squidoc/core": "workspace:*",
    "astro": "^5.13.0",
    "chokidar": "^4.0.3",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
