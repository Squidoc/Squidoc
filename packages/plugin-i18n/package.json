{
  "name": "@squidoc/plugin-i18n",
  "version": "0.1.0",
  "description": "Internationalized documentation support for Squidoc.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "homepage": "https://github.com/Squidoc/Squidoc#readme",
  "bugs": {
    "url": "https://github.com/Squidoc/Squidoc/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Squidoc/Squidoc.git",
    "directory": "packages/plugin-i18n"
  },
  "keywords": ["docs", "documentation", "i18n", "localization", "squidoc", "plugin"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@squidoc/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
