{
  "name": "create-squidoc",
  "version": "0.1.0",
  "description": "Project generator for Squidoc.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "homepage": "https://github.com/Squidoc/Squidoc#readme",
  "bugs": {
    "url": "https://github.com/Squidoc/Squidoc/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Squidoc/Squidoc.git",
    "directory": "packages/create-squidoc"
  },
  "keywords": ["docs", "documentation", "generator", "squidoc", "static-site"],
  "bin": {
    "create-squidoc": "./dist/cli.js"
  },
  "files": ["dist", "template"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
