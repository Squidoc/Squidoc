{
  "name": "squidoc-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "build": "pnpm -r --filter './packages/**' build",
    "build:docs": "pnpm --filter @squidoc/docs build",
    "check": "pnpm -r --filter './packages/**' check",
    "check:docs": "pnpm --filter @squidoc/docs check",
    "clean": "pnpm -r --filter './packages/**' clean",
    "format": "biome format --write .",
    "lint": "biome check .",
    "test": "pnpm -r --filter './packages/**' test && pnpm check:docs && pnpm build:docs && pnpm test:dogfood && pnpm test:generator",
    "test:dogfood": "node scripts/smoke-dogfood-site.mjs",
    "test:generator": "node scripts/smoke-create-squidoc.mjs",
    "version-packages": "changeset version",
    "publish-packages": "pnpm build && changeset publish",
    "changeset": "changeset"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.29.5",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
